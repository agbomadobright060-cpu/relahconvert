{
  "manifest_version": 3,
  "name": "RelahConvert — Free Image Tools",
  "version": "1.0.0",
  "description": "Right-click any image to compress, resize, convert, or remove background. 30+ free image tools.",
  "permissions": ["contextMenus", "activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
